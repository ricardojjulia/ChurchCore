{
  "name": "churchcore",
  "version": "3.2.0",
  "private": true,
  "license": "MIT",
  "description": "ChurchCore is a professional, compliance-first platform for modern church operations, combining secure architecture with end-to-end workflows across member care, events, giving, finance, and reporting.",
  "scripts": {
    "dev": "next dev -p 4200",
    "build": "next build",
    "start": "next start -p 4200",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:readiness": "playwright test tests/e2e/church-admin-readiness.spec.ts",
    "test:e2e:member-mobile": "playwright test tests/e2e/member-mobile-foundation.spec.ts",
    "test:e2e:onboarding": "playwright test tests/e2e/onboarding-flow.spec.ts",
    "check": "npm run lint && npm run build",
    "postinstall": "rm -rf node_modules/next/node_modules/postcss",
    "setup:local": "./supabase/scripts/setup-local.sh",
    "smoke:preview": "./supabase/scripts/smoke-demo.sh preview",
    "smoke:local": "./supabase/scripts/smoke-demo.sh local",
    "lint:migrations": "node scripts/lint-migrations.mjs",
    "check:schema": "node scripts/check-schema-alignment.mjs",
    "audit:rls": "node scripts/audit-rls.mjs",
    "generate:manifest": "node scripts/generate-manifest.mjs",
    "setup:demo": "node scripts/seed-demo.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@mantine/core": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "@mantine/notifications": "^9.0.1",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@types/papaparse": "^5.5.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.6",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "postcss": "^8.5.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "read-excel-file": "^9.0.6",
    "svix": "^1.95.1",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^26.1.0",
    "server-only": "^0.0.1",
    "supabase": "^2.89.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "ws": ">=8.20.1",
    "minimatch@>=10.0.0": {
      "brace-expansion": ">=5.0.6"
    },
    "next": {
      "postcss": ">=8.5.10"
    }
  }
}
