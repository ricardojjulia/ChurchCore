# ─────────────────────────────────────────────────────────
# Supabase — Tenant project
# ─────────────────────────────────────────────────────────

# Server-side client (not exposed to browser)
TENANT_SUPABASE_URL=
TENANT_SUPABASE_PUBLISHABLE_KEY=
TENANT_SUPABASE_SERVICE_ROLE_KEY=

# Browser-side client (NEXT_PUBLIC_ prefix required for client components)
# Set to the same project as TENANT_SUPABASE_* above
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Local dev only — activates shouldUseLocalTenantDbFallback(); DO NOT set in production
TENANT_DB_URL=

# ─────────────────────────────────────────────────────────
# Supabase — Control plane project (separate Supabase project)
# ─────────────────────────────────────────────────────────

CONTROL_PLANE_SUPABASE_URL=
CONTROL_PLANE_SUPABASE_PUBLISHABLE_KEY=
CONTROL_PLANE_SUPABASE_SERVICE_ROLE_KEY=

# Local dev only — activates shouldUseLocalControlPlaneFallback(); DO NOT set in production
CONTROL_PLANE_DB_URL=

# ─────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:4200

# Cron route authentication — required in production, optional in local dev
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─────────────────────────────────────────────────────────
# Security — Data Encryption (Phase 2 hardening, PR #111)
# ─────────────────────────────────────────────────────────

# AES-256-GCM key for encrypting pastoral_notes.content and care_assignments.summary at rest.
# REQUIRED in production — app throws on any pastoral read/write if absent in NODE_ENV=production.
# In local dev: omit or leave blank to use plaintext fallback (a console warning is shown).
# Generate with: openssl rand -base64 32
# WARNING: loss of this key = permanent loss of all encrypted pastoral data. Back it up.
PASTORAL_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────
# Communications — Email (Resend — primary provider)
# When absent, adapter returns stub results (safe for local dev)
# ─────────────────────────────────────────────────────────

RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Resend webhook signing secret — copy the full whsec_... string from Resend dashboard
RESEND_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────
# Communications — Email (SendGrid — alternative provider)
# ─────────────────────────────────────────────────────────

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_WEBHOOK_VERIFICATION_KEY=

# ─────────────────────────────────────────────────────────
# Communications — SMS (Twilio)
# ─────────────────────────────────────────────────────────

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Unsubscribe link HMAC signing secret — required in production
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=

# ─────────────────────────────────────────────────────────
# Payments — Stripe
# When absent, donation initiation returns a stub client_secret (safe for local dev)
# ─────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─────────────────────────────────────────────────────────
# AI Ministry Tools — Anthropic Claude (CC-AI-001, Sprint 5)
# When absent, AI features return a graceful "not configured" error (safe for local dev)
# Get your API key from: https://console.anthropic.com
# ─────────────────────────────────────────────────────────

# Server-side only — never prefix with NEXT_PUBLIC_
ANTHROPIC_API_KEY=
# Optional — defaults to claude-haiku-4-5-20251001
AI_MINISTRY_MODEL=

# ─────────────────────────────────────────────────────────
# Web-Push Notifications (optional)
# Generate key pair: npx web-push generate-vapid-keys
# When absent, push notification dispatch is skipped gracefully
# ─────────────────────────────────────────────────────────

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─────────────────────────────────────────────────────────
# Legacy / do not use for new code
# ─────────────────────────────────────────────────────────

# Pre-ADR 0002 single-backend vars — kept for reference only
# NEXT_PUBLIC_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are superseded
# by TENANT_SUPABASE_* and NEXT_PUBLIC_SUPABASE_* above
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Optional local demo bootstrap override
CHURCHFORGE_DEV_PASSWORD=
